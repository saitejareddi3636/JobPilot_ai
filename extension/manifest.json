{
  "manifest_version": 3,
  "name": "JobPilot AI",
  "version": "1.0.0",
  "description": "Fill job application forms instantly with your saved profile",
  "action": {
    "default_popup": "popup.html",
    "default_title": "JobPilot AI"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
